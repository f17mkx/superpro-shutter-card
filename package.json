{
  "name": "superpro-shutter-card",
  "version": "1.0.7",
  "description": "Branded Home Assistant Lovelace card for animated shutter/cover control",
  "type": "module",
  "private": true,
  "license": "GPL-3.0-or-later",
  "author": "Stefan Volk <stefan.volk23@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/f17mkx/superpro-shutter-card.git"
  },
  "scripts": {
    "build": "rollup -c",
    "build:check": "rollup -c && node scripts/check-dist-drift.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "lint": "eslint src/ tests/"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "happy-dom": "^15.11.7",
    "lit": "^3.2.1",
    "rollup": "^4.29.1",
    "vitest": "^2.1.8"
  }
}
